{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cirrus-drive",
  "main": "src/index.tsx",
  "compatibility_date": "2026-05-03",
  "observability": {
    "enabled": true
  },
  "r2_buckets": [
    {
      "binding": "DRIVE_BUCKET",
      "bucket_name": "cirrus-drive"
    }
  ]
}
