{
  "name": "cirrus-drive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:r2": "wrangler dev --config wrangler.jsonc",
    "dev:s3": "wrangler dev --config wrangler.s3.jsonc",
    "deploy": "node scripts/deploy.mjs",
    "deploy:r2": "wrangler deploy --experimental-provision --config wrangler.jsonc",
    "deploy:s3": "wrangler deploy --experimental-provision --config wrangler.s3.jsonc",
    "test": "npm run typecheck && npm run test:e2e",
    "test:e2e": "node scripts/e2e.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "fast-xml-parser": "^5.7.3",
    "hono": "^4.8.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250816.0",
    "esbuild": "^0.27.3",
    "miniflare": "^4.20260426.0",
    "typescript": "^5.9.2",
    "wrangler": "4.86.0"
  }
}
