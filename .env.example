# Authentication.
# Format: username:password:role,username:password:role
# Role can be admin or user. Put real values in Cloudflare Worker Secrets.
# Add or remove login accounts here; the /admin page manages role overrides,
# user tags, visible tags, visible files, nicknames, avatars, status, password overrides, friends, and notifications after login exists.
AUTH_USERS=admin:change-me:admin,alice:alice-password:user
CSRF_SECRET=replace-with-a-random-secret

# S3 storage settings.
# Copy these values into Cloudflare Worker Variables and Secrets when using S3.
# For local S3 development, copy this file to .dev.vars and fill the values.

# Recommended when using S3.
S3_BUCKET=your-s3-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# S3_REGION defaults to us-east-1 when omitted, but it should match your bucket region.

# Optional. Only needed for S3-compatible services such as MinIO.
# AWS S3 usually does not need these.
# S3_ENDPOINT=https://s3.example.com
# S3_FORCE_PATH_STYLE=true

# Optional. Only needed for temporary credentials.
# S3_SESSION_TOKEN=your-session-token

# Optional security limits. Defaults are safe for most small deployments.
# MAX_FILE_BYTES=104857600
# MAX_UPLOAD_BYTES=262144000
# MAX_FILES_PER_UPLOAD=50
# MAX_JSON_BYTES=65536
# MAX_SELECTED_FILES=500
# MAX_SHARE_FILES=100
# API_RATE_LIMIT_PER_MINUTE=300
# AUTH_RATE_LIMIT_PER_MINUTE=60
# SHARE_VERIFY_RATE_LIMIT_PER_MINUTE=30

# Optional local-only fallback. Do not enable on public deployments.
# ALLOW_UNCONFIGURED_AUTH=false
